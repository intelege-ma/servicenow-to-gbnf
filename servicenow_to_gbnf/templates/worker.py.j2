"""Generated iii worker for ServiceNow {{ table | title }} - deterministic via GBNF.

Generated by servicenow-to-gbnf v{{ tool_version }} on {{ generated_at }}.

Required environment variables:
    SERVICENOW_USERNAME    Basic-auth username for the ServiceNow instance
    SERVICENOW_PASSWORD    Basic-auth password for the ServiceNow instance
    III_ENGINE_URL         (optional) iii engine WS URL, defaults to ws://localhost:49134
    OLLAMA_MODEL           (optional) Ollama model name, defaults to llama3.2
"""
from __future__ import annotations

import asyncio
import json
import os
from pathlib import Path

import httpx
import ollama
from iii import III

# Load grammar once at startup. Path is resolved relative to this worker file
# so the worker can be moved/run from any directory.
GRAMMAR_PATH = Path(__file__).parent / "{{ grammar_filename }}"
GRAMMAR = GRAMMAR_PATH.read_text(encoding="utf-8")

SERVICENOW_INSTANCE = os.getenv("SERVICENOW_INSTANCE", "{{ servicenow_instance }}")
SERVICENOW_USERNAME = os.getenv("SERVICENOW_USERNAME")
SERVICENOW_PASSWORD = os.getenv("SERVICENOW_PASSWORD")

iii = III(os.getenv("III_ENGINE_URL", "ws://localhost:49134"))


async def {{ python_function_name }}(data: dict) -> dict:
    """Deterministic ServiceNow {{ table | title }} create/update via GBNF-constrained LLM.

    Input:  dict with at least ``description`` and ``short_description``.
    Output: dict with ServiceNow ``sys_id`` + the full record on success,
            or ``{"success": False, "error": "..."}`` on failure.
    """
    if not (SERVICENOW_USERNAME and SERVICENOW_PASSWORD):
        return {
            "success": False,
            "error": "SERVICENOW_USERNAME / SERVICENOW_PASSWORD env vars are not set.",
        }

    try:
        # 1. Build the prompt from the user-supplied data + the static system prompt.
        user_prompt = (
            f"Create a valid ServiceNow {{ table | title }} record:\n"
            f"{json.dumps(data, indent=2)}"
        )
        system_prompt = (Path(__file__).parent / "system_prompt.txt").read_text(encoding="utf-8")

        # 2. Call the local LLM with GBNF-constrained decoding via ollama.
        response = ollama.generate(
            model=os.getenv("OLLAMA_MODEL", "llama3.2"),
            prompt=f"{system_prompt}\n\n{user_prompt}",
            format="json",
        )
        payload = json.loads(response["response"])

        # 3. POST the constrained payload to the ServiceNow Table API.
        async with httpx.AsyncClient() as client:
            resp = await client.post(
                f"{SERVICENOW_INSTANCE.rstrip('/')}/api/now/table/{{ table }}",
                json=payload,
                auth=(SERVICENOW_USERNAME, SERVICENOW_PASSWORD),
                headers={"Content-Type": "application/json"},
                timeout=30.0,
            )
            resp.raise_for_status()
            result = resp.json()

        return {
            "success": True,
            "sys_id": result.get("result", {}).get("sys_id"),
            "record": result.get("result"),
            "raw_payload": payload,
        }
    except Exception as exc:  # noqa: BLE001 - return errors structured for iii callers
        return {"success": False, "error": str(exc)}


async def main() -> None:
    await iii.connect()

    iii.register_function("{{ iii_function_id }}", {{ python_function_name }})
